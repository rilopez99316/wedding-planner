// Wedding Planning Platform — Full Schema
// All modules connect to Wedding via weddingId.
// P2+ module stubs are included as comments — uncomment when building each module.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH.JS REQUIRED TABLES
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE PLATFORM
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  weddings      Wedding[]
}

model Wedding {
  id            String   @id @default(cuid())
  slug          String   @unique
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  partner1Name  String
  partner2Name  String
  weddingDate   DateTime
  rsvpDeadline  DateTime

  venueName     String?
  venueAddress  String?

  accentColor   String   @default("#0071E3")
  coverPhotoUrl String?
  totalBudget   Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  events      WeddingEvent[]
  guestGroups GuestGroup[]

  // P2: Uncomment when building each module
  // vendors          Vendor[]
  budgetCategories BudgetCategory[]
  // checklistItems   ChecklistItem[]
  // weddingParty     WeddingPartyMember[]
  // seatingTables    SeatingTable[]
  registries       Registry[]
}

// ─────────────────────────────────────────────────────────────────────────────
// P1: RSVP MODULE
// ─────────────────────────────────────────────────────────────────────────────

model WeddingEvent {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  key       String
  label     String
  date      DateTime
  location  String?
  notes     String?
  order     Int      @default(0)

  @@unique([weddingId, key])
  guestGroupEvents GuestGroupEvent[]
}

model GuestGroup {
  id                 String   @id @default(cuid())
  weddingId          String
  wedding            Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  groupName          String
  hasPlusOne         Boolean  @default(false)
  plusOneNameIfKnown String?
  invitationTier     String   @default("A")
  createdAt          DateTime @default(now())

  guests        Guest[]
  allowedEvents GuestGroupEvent[]
  rsvpResponse  RsvpResponse?
}

model GuestGroupEvent {
  groupId String
  eventId String
  group   GuestGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  event   WeddingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([groupId, eventId])
}

model Guest {
  id               String     @id @default(cuid())
  weddingId        String
  groupId          String
  group            GuestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  email            String?
  phone            String?
  address          String?
  isPlusOne        Boolean    @default(false)
  invitationToken  String?    @unique
  invitationSentAt DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  dietaryRestrictions DietaryRestriction[]
}

model RsvpResponse {
  id               String     @id @default(cuid())
  groupId          String     @unique
  group            GuestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  submittedAt      DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  plusOneAttending     Boolean  @default(false)
  plusOneName          String?
  plusOneDietaryNotes  String?

  eventResponses EventResponse[]
}

model EventResponse {
  id        String       @id @default(cuid())
  rsvpId    String
  rsvp      RsvpResponse @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  eventKey  String
  attending Boolean

  @@unique([rsvpId, eventKey])
}

model DietaryRestriction {
  id          String  @id @default(cuid())
  guestId     String
  guest       Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)
  restriction String
  notes       String?
}

