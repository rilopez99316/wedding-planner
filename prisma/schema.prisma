// ─────────────────────────────────────────────────────────────────────────────
// P2: REGISTRY MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum RegistryType {
  REGISTRY
  FUND
}

model Registry {
  id          String       @id @default(cuid())
  weddingId   String
  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  type        RegistryType @default(REGISTRY)
  store       String
  url         String
  description String?
  isPublic    Boolean      @default(true)
  createdAt   DateTime     @default(now())
}

