// Wedding Planning Platform — Full Schema
// All modules connect to Wedding via weddingId.
// P2+ module stubs are included as comments — uncomment when building each module.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH.JS REQUIRED TABLES
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE PLATFORM
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  weddings      Wedding[]
}

model Wedding {
  id            String   @id @default(cuid())
  slug          String   @unique
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  partner1Name  String
  partner2Name  String
  weddingDate   DateTime
  rsvpDeadline  DateTime

  venueName     String?
  venueAddress  String?

  accentColor   String   @default("#0071E3")
  colorPalette  String   @default("classic-ivory")
  coverPhotoUrl String?
  totalBudget   Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  events      WeddingEvent[]
  guestGroups GuestGroup[]

  // P2: Uncomment when building each module
  vendors          Vendor[]
  budgetCategories BudgetCategory[]
  checklistItems   ChecklistItem[]
  weddingParty     WeddingPartyMember[]
  seatingTables    SeatingTable[]
  registries       Registry[]
  timelineEvents   TimelineEvent[]
  ceremonyProgram  CeremonyProgram?
  musicPlan        MusicPlan?
  accommodations   HotelBlock[]
  guestMessages    GuestMessage[]
  gifts            Gift[]
}

// ─────────────────────────────────────────────────────────────────────────────
// P1: RSVP MODULE
// ─────────────────────────────────────────────────────────────────────────────

model WeddingEvent {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  key       String
  label     String
  date      DateTime
  location  String?
  notes     String?
  order     Int      @default(0)

  @@unique([weddingId, key])
  guestGroupEvents GuestGroupEvent[]
}

model GuestGroup {
  id                 String   @id @default(cuid())
  weddingId          String
  wedding            Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  groupName          String
  hasPlusOne         Boolean  @default(false)
  plusOneNameIfKnown String?
  invitationTier     String   @default("A")
  createdAt          DateTime @default(now())

  guests        Guest[]
  allowedEvents GuestGroupEvent[]
  rsvpResponse  RsvpResponse?

  @@index([weddingId])
}

model GuestGroupEvent {
  groupId String
  eventId String
  group   GuestGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  event   WeddingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([groupId, eventId])
}

model Guest {
  id               String     @id @default(cuid())
  weddingId        String
  groupId          String
  group            GuestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  email            String?
  phone            String?
  address          String?
  isPlusOne        Boolean    @default(false)
  invitationToken  String?    @unique
  invitationSentAt DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  dietaryRestrictions DietaryRestriction[]
  seatingAssignment   SeatingAssignment?
  gifts               Gift[]

  @@index([weddingId])
  @@index([groupId])
}

model RsvpResponse {
  id               String     @id @default(cuid())
  groupId          String     @unique
  group            GuestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  submittedAt      DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  plusOneAttending     Boolean  @default(false)
  plusOneName          String?
  plusOneDietaryNotes  String?

  eventResponses EventResponse[]
}

model EventResponse {
  id        String       @id @default(cuid())
  rsvpId    String
  rsvp      RsvpResponse @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  eventKey  String
  attending Boolean

  @@unique([rsvpId, eventKey])
  @@index([rsvpId])
}

model DietaryRestriction {
  id          String  @id @default(cuid())
  guestId     String
  guest       Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)
  restriction String
  notes       String?

  @@index([guestId])
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: CHECKLIST MODULE
// ─────────────────────────────────────────────────────────────────────────────
model ChecklistItem {
  id          String    @id @default(cuid())
  weddingId   String
  wedding     Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title       String
  category    String
  dueDate     DateTime?
  completedAt DateTime?
  isCustom    Boolean   @default(false)
  order       Int       @default(0)
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: BUDGET MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  DEPOSIT_PAID
  PAID
}

model BudgetCategory {
  id        String       @id @default(cuid())
  weddingId String
  wedding   Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  color     String       @default("#6B7280")
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  items     BudgetItem[]
}

model BudgetItem {
  id            String         @id @default(cuid())
  weddingId     String
  categoryId    String
  category      BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name          String
  estimatedCost Float          @default(0)
  actualCost    Float?
  amountPaid    Float          @default(0)
  vendorName    String?
  dueDate       DateTime?
  notes         String?
  paymentStatus PaymentStatus  @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: VENDOR MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Vendor {
  id          String          @id @default(cuid())
  weddingId   String
  wedding     Wedding         @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  category    String          // "venue" | "photographer" | "caterer" | "florist" | "dj" | "other"
  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  notes       String?
  status      String          @default("prospect") // "prospect" | "shortlisted" | "booked" | "rejected"
  packages    VendorPackage[]
  documents   VendorDocument[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model VendorPackage {
  id         String   @id @default(cuid())
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name       String
  price      Float?
  capacity   Int?
  inclusions String?
  notes      String?
  createdAt  DateTime @default(now())
}

model VendorDocument {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name      String
  url       String
  fileType  String
  fileSize  Int?
  createdAt DateTime @default(now())

  @@index([vendorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: WEDDING PARTY MODULE
// ─────────────────────────────────────────────────────────────────────────────
enum WeddingPartyRole {
  MOH
  BRIDESMAID
  BEST_MAN
  GROOMSMAN
  FLOWER_GIRL
  RING_BEARER
  PARENT_OF_BRIDE
  PARENT_OF_GROOM
  OFFICIANT
  OTHER
}

enum WeddingPartySide {
  BRIDE
  GROOM
  BOTH
}

model WeddingPartyMember {
  id           String           @id @default(cuid())
  weddingId    String
  wedding      Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  name         String
  role         WeddingPartyRole
  side         WeddingPartySide
  photoUrl     String?

  email        String?
  phone        String?
  notes        String?          @db.Text
  displayOrder Int              @default(0)
  isPublic     Boolean          @default(true)

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([weddingId, displayOrder])
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: SEATING MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum TableShape {
  ROUND
  RECTANGULAR
}

model SeatingTable {
  id        String     @id @default(cuid())
  weddingId String
  wedding   Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  capacity  Int
  shape     TableShape @default(ROUND)
  notes     String?    @db.Text
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  assignments SeatingAssignment[]

  @@index([weddingId, sortOrder])
}

model SeatingAssignment {
  tableId    String
  guestId    String   @unique
  seatNumber Int?     // 1-based seat position within the table; null = assigned to table only
  table      SeatingTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guest      Guest        @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@id([tableId, guestId])
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: REGISTRY MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum RegistryType {
  REGISTRY
  FUND
}

model Registry {
  id          String       @id @default(cuid())
  weddingId   String
  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  type        RegistryType @default(REGISTRY)
  store       String
  url         String
  description String?
  isPublic    Boolean      @default(true)
  createdAt   DateTime     @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: TIMELINE MODULE
// ─────────────────────────────────────────────────────────────────────────────

model TimelineEvent {
  id         String    @id @default(cuid())
  weddingId  String
  wedding    Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title      String
  startTime  DateTime
  endTime    DateTime?
  category   String    // getting_ready | travel | ceremony | photos | cocktail_hour | reception | other
  location   String?
  assignedTo String?
  notes      String?   @db.Text
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([weddingId, startTime])
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: CEREMONY MODULE
// ─────────────────────────────────────────────────────────────────────────────

model CeremonyProgram {
  id        String   @id @default(cuid())
  weddingId String   @unique
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  partner1Vows       String?  @db.Text
  partner2Vows       String?  @db.Text
  partner1VowsPin    String?
  partner2VowsPin    String?
  partner1VowsStatus String   @default("not_started")
  partner2VowsStatus String   @default("not_started")
  processionalSong   String?
  recessionalSong    String?
  notes              String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CeremonyItem[]
}

model CeremonyItem {
  id        String          @id @default(cuid())
  programId String
  program   CeremonyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  type        String   // processional | welcome | reading | prayer | music_moment | vows | rings | unity | pronouncement | recessional | custom
  title       String
  description String?  @db.Text
  assignedTo  String?
  notes       String?  @db.Text
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId, order])
}

// ─────────────────────────────────────────────────────────────────────────────
// MUSIC MODULE
// ─────────────────────────────────────────────────────────────────────────────

model MusicPlan {
  id        String   @id @default(cuid())
  weddingId String   @unique
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  grandEntranceSong        String?
  firstDanceSong           String?
  fatherDaughterSong       String?
  motherSonSong            String?
  weddingPartyEntranceSong String?
  cakeCuttingSong          String?
  lastDanceSong            String?
  djNotes                  String?  @db.Text

  mustPlayPlaylistUrl   String?
  doNotPlayPlaylistUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  songs MusicSong[]
}

model MusicSong {
  id          String    @id @default(cuid())
  musicPlanId String
  musicPlan   MusicPlan @relation(fields: [musicPlanId], references: [id], onDelete: Cascade)
  title       String
  artist      String?
  listType    String    // "must_play" | "do_not_play"
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([musicPlanId, listType, order])
}

// ─────────────────────────────────────────────────────────────────────────────
// ACCOMMODATIONS MODULE
// ─────────────────────────────────────────────────────────────────────────────

model HotelBlock {
  id            String    @id @default(cuid())
  weddingId     String
  wedding       Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  name          String
  address       String?
  bookingUrl    String?
  promoCode     String?
  roomsTotal    Int?
  roomsBooked   Int       @default(0)
  pricePerNight Float?
  checkInDate   DateTime?
  checkOutDate  DateTime?
  deadline      DateTime?
  notes         String?   @db.Text
  order         Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([weddingId, order])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMUNICATIONS MODULE
// ─────────────────────────────────────────────────────────────────────────────

model GuestMessage {
  id              String    @id @default(cuid())
  weddingId       String
  wedding         Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  subject         String?
  body            String    @db.Text
  channel         String    // "email" | "sms"
  status          String    @default("draft") // "draft" | "scheduled" | "sending" | "sent" | "failed"

  recipientFilter String    @default("all") // "all" | "attending" | "not_responded" | "declined"
  recipientCount  Int?

  scheduledAt     DateTime?
  sentAt          DateTime?

  totalSent       Int       @default(0)
  totalFailed     Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([weddingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// THANK-YOU TRACKER MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Gift {
  id        String  @id @default(cuid())
  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  // Giver — optional link to a Guest row; always store a free-text name too
  guestId   String?
  guest     Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)
  giverName String  // free-text (covers companies, family groups, unlisted guests)

  // Gift details
  description String
  category    String? // "cash" | "registry" | "experience" | "other"
  value       Float?
  receivedAt  DateTime?
  notes       String? @db.Text

  // Thank-you workflow
  thankYouStatus String    @default("pending") // "pending" | "drafted" | "sent"
  thankYouNote   String?   @db.Text
  thankYouSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
}
