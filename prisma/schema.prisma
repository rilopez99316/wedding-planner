// ─────────────────────────────────────────────────────────────────────────────
// P2: REGISTRY MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum RegistryType {
  REGISTRY
  FUND
}

model Registry {
  id          String       @id @default(cuid())
  weddingId   String
  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  type        RegistryType @default(REGISTRY)
  store       String
  url         String
  description String?
  isPublic    Boolean      @default(true)
  createdAt   DateTime     @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// P2: TIMELINE MODULE
// ─────────────────────────────────────────────────────────────────────────────

model TimelineEvent {
  id         String    @id @default(cuid())
  weddingId  String
  wedding    Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title      String
  startTime  DateTime
  endTime    DateTime?
  category   String    // getting_ready | travel | ceremony | photos | cocktail_hour | reception | other
  location   String?
  assignedTo String?
  notes      String?   @db.Text
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([weddingId, startTime])
}

